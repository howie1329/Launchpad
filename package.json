{
	"name": "Launchpad",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"generate:openui": "openui generate src/lib/openui/prompt-library.ts --out src/lib/openui/generated/system-prompt.txt --no-interactive",
		"predev": "npm run generate:openui",
		"dev": "vite dev",
		"predev:all": "npm run generate:openui",
		"dev:all": "concurrently \"vite dev\" \"convex dev\"",
		"prebuild": "npm run generate:openui",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"predev:frontend": "npm run generate:openui",
		"dev:frontend": "vite dev",
		"dev:backend": "convex dev",
		"eval:chat": "braintrust eval evals/workspace-chat/workspace-chat.eval.ts"
	},
	"devDependencies": {
		"@ai-sdk/svelte": "^5.0.29",
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/inter": "^5.2.8",
		"@hugeicons/core-free-icons": "^4.2.2",
		"@hugeicons/svelte": "^1.1.4",
		"@internationalized/date": "^3.12.0",
		"@openuidev/cli": "^0.0.8",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.69.3",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.2",
		"@types/node": "^24",
		"ai": "^7.0.29",
		"bits-ui": "^2.17.3",
		"clsx": "^2.1.1",
		"concurrently": "^9.2.1",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"formsnap": "^2.0.1",
		"globals": "^17.4.0",
		"paneforge": "^1.0.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.1",
		"shadcn-svelte": "^1.4.2",
		"svelte": "^5.56.5",
		"svelte-check": "^4.7.3",
		"sveltekit-superforms": "^2.30.2",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.9",
		"zod": "^4.3.6"
	},
	"dependencies": {
		"@auth/core": "^0.37.0",
		"@codemirror/lang-html": "^6.4.11",
		"@codemirror/lang-markdown": "^6.5.1",
		"@codemirror/merge": "^6.12.2",
		"@codemirror/state": "^6.7.1",
		"@codemirror/view": "^6.43.6",
		"@composio/core": "^0.13.1",
		"@composio/vercel": "^0.11.0",
		"@convex-dev/auth": "^0.0.91",
		"@fontsource/geist-sans": "^5.2.5",
		"@openrouter/ai-sdk-provider": "^3.0.0",
		"@openuidev/lang-core": "^0.2.6",
		"@openuidev/svelte-lang": "^0.1.2",
		"@pierre/diffs": "^1.1.16",
		"@shikijs/themes": "^4.0.2",
		"@tavily/core": "^0.7.6",
		"braintrust": "^3.22.0",
		"codemirror": "^6.0.2",
		"convex": "^1.42.2",
		"convex-svelte": "^0.14.0",
		"mode-watcher": "^1.1.0",
		"runed": "^0.37.1",
		"supermemory": "^4.24.12",
		"svelte-streamdown": "^3.1.2",
		"thomas-agentkit": "^0.9.0"
	}
}
